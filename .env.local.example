# ── Alpaca Trading API ─────────────────────────────────
# 미국 주식 시세 데이터를 가져오기 위해 사용됩니다.
# https://alpaca.markets 에서 회원가입 후 API Key를 발급받을 수 있습니다.
# (Paper Trading용 무료 키로도 실시간 시세 조회가 가능합니다.)
ALPACA_API_KEY_ID=YOUR_ALPACA_API_KEY_ID_HERE
ALPACA_SECRET_KEY=YOUR_ALPACA_SECRET_KEY_HERE

# ── 한국투자증권 Open API ──────────────────────────────
# 국내 주식 시세 데이터를 가져오기 위해 사용됩니다.
# https://apiportal.koreainvestment.com/ 에서 회원가입 및 서비스 신청 후 AppKey/SecretKey를 발급받으세요.
KOREA_INVESTMENT_API_KEY=YOUR_KOREA_INVESTMENT_API_KEY_HERE
KOREA_INVESTMENT_API_SECRET=YOUR_KOREA_INVESTMENT_API_SECRET_HERE

# [선택사항] 한국투자증권 종합계좌번호 (8자리 숫자)
# 전략 조회 기능만 사용할 경우 입력하지 않아도 무방합니다.
KOREA_INVESTMENT_ACCOUNT=YOUR_ACCOUNT_NUMBER_HERE

# [선택사항] 한국투자증권 접속 모드 설정
# 모의투자(Sandbox) 계정인 경우 아래 설정값을 'mock'으로 설정하여 모의 서버(openapivts.koreainvestment.com:29443)로 접속하게 합니다.
# 실전투자 계정인 경우 아래 라인을 주석 처리(#)하거나 비워두면 실전 서버(openapi.koreainvestment.com:9443)로 자동 연결됩니다.
# KOREA_INVESTMENT_MODE=mock

# ── Discord 웹훅 (포지션 일일 알림) ───────────────────
# Discord 채널 설정 → 웹후크 → URL 복사 후 아래에 붙여넣기
# 알림 전송: 브라우저에서 http://localhost:3000/api/positions/notify 열기
# 자동화: Windows 작업 스케줄러로 매일 아침 curl http://localhost:3000/api/positions/notify 실행
DISCORD_WEBHOOK_URL=YOUR_DISCORD_WEBHOOK_URL_HERE

# ── Google Gemini API ──────────────────────────────────
# 수집된 주식 지표 데이터를 기반으로 투자 분석 및 매매 전략 시나리오를 자동 수립하는 AI 모델입니다.
# https://aistudio.google.com/app/apikey 에서 API 키를 무료로 발급받을 수 있습니다.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── Supabase PostgreSQL ────────────────────────────────
# 로그인/회원가입 및 포지션·관심종목 데이터 저장에 사용됩니다.
# https://supabase.com 에서 프로젝트 생성 후 Settings → Database → Connection string (Session mode) 복사
# 비밀번호의 특수문자는 URL 인코딩 필요 (예: ! → %21)
DATABASE_URL=postgresql://postgres.[프로젝트ID]:[비밀번호]@aws-0-[리전].pooler.supabase.com:5432/postgres

# ── NextAuth ──────────────────────────────────────────
# JWT 세션 암호화에 사용되는 랜덤 시크릿 키입니다.
# 터미널에서 생성: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=YOUR_NEXTAUTH_SECRET_HERE
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth ──────────────────────────────────────
# Google 소셜 로그인에 사용됩니다.
# Google Cloud Console → API 및 서비스 → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID 생성
# 승인된 리디렉션 URI에 http://localhost:3000/api/auth/callback/google 추가 필요
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# ── 허용된 사용자 (쉼표로 구분, 비워두면 모든 사용자 허용) ──
# 예: ALLOWED_EMAILS=user1@gmail.com,user2@gmail.com
ALLOWED_EMAILS=
