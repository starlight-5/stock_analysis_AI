# ── 한국투자증권 Open API ──────────────────────────────
# 국내 주식 시세·차트·시간외 가격 데이터를 가져오기 위해 사용됩니다.
# https://apiportal.koreainvestment.com/ 에서 회원가입 및 서비스 신청 후 AppKey/SecretKey를 발급받으세요.
# 한국투자증권 계좌(실전투자 또는 모의투자)가 필요합니다.
KOREA_INVESTMENT_API_KEY=YOUR_KOREA_INVESTMENT_API_KEY_HERE
KOREA_INVESTMENT_API_SECRET=YOUR_KOREA_INVESTMENT_API_SECRET_HERE

# [선택사항] 한국투자증권 종합계좌번호 (8자리 숫자)
# 시세·전략 조회 기능만 사용할 경우 입력하지 않아도 무방합니다.
KOREA_INVESTMENT_ACCOUNT=YOUR_ACCOUNT_NUMBER_HERE

# [선택사항] 한국투자증권 접속 모드
# 모의투자(Sandbox) 계정인 경우 'mock'으로 설정 → openapivts.koreainvestment.com:29443 서버 사용
# 실전투자 계정이면 이 줄을 주석 처리하거나 비워두세요 → openapi.koreainvestment.com:9443 자동 연결
# KOREA_INVESTMENT_MODE=mock

# ── Google Gemini API ──────────────────────────────────
# 기술적 지표·뉴스·실적 데이터를 바탕으로 매매 전략을 자동 수립하는 AI 모델입니다.
# https://aistudio.google.com/app/apikey 에서 무료 발급 가능합니다.
# 없어도 규칙 기반 폴백 엔진으로 모든 기능이 작동합니다.
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# ── Supabase PostgreSQL ────────────────────────────────
# 사용자 계정·포지션·관심종목·접근 요청·차단 이메일 데이터 저장에 사용됩니다.
# https://supabase.com 에서 프로젝트 생성 후 Settings → Database → Connection string (Session mode) 복사
# 비밀번호의 특수문자는 URL 인코딩 필요 (예: ! → %21)
DATABASE_URL=postgresql://postgres.[프로젝트ID]:[비밀번호]@aws-0-[리전].pooler.supabase.com:5432/postgres

# ── NextAuth ──────────────────────────────────────────
# JWT 세션 암호화에 사용되는 랜덤 시크릿 키입니다.
# 생성 방법: openssl rand -base64 32
NEXTAUTH_SECRET=YOUR_NEXTAUTH_SECRET_HERE
NEXTAUTH_URL=http://localhost:3000

# ── Google OAuth ──────────────────────────────────────
# Google 소셜 로그인에 사용됩니다.
# Google Cloud Console → API 및 서비스 → 사용자 인증 정보 → OAuth 2.0 클라이언트 ID 생성
# 승인된 리디렉션 URI에 http://localhost:3000/api/auth/callback/google 추가 필요
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# ── 관리자 이메일 ──────────────────────────────────────
# 이 이메일 계정만 항상 로그인 허용 + /admin 페이지(접근 요청 승인·사용자 관리) 접근 가능
# 다른 사용자는 관리자가 접근 요청을 승인해야 로그인할 수 있습니다.
ADMIN_EMAIL=YOUR_ADMIN_EMAIL_HERE
# 클라이언트에서 어드민 여부 판별용 (ADMIN_EMAIL과 동일한 값으로 설정)
# /recommendations 페이지의 '이어서 생성' 버튼 표시 여부에 사용됩니다.
NEXT_PUBLIC_ADMIN_EMAIL=YOUR_ADMIN_EMAIL_HERE

# ── Discord 웹훅 (포지션 알림) ────────────────────────
# 포지션 등록·종료 시 Discord 채널로 알림을 전송합니다.
# Discord 채널 설정 → 웹후크 → URL 복사 후 아래에 붙여넣기 (선택사항)
DISCORD_WEBHOOK_URL=YOUR_DISCORD_WEBHOOK_URL_HERE

# ── Cron 보안 시크릿 ──────────────────────────────────
# Vercel Cron이 /api/recommendations/generate 호출 시 자동으로 첨부하는 Bearer 토큰입니다.
# Vercel 프로젝트 Settings → Environment Variables에도 동일 값을 등록해야 합니다.
# 생성 방법: openssl rand -base64 32
CRON_SECRET=YOUR_CRON_SECRET_HERE

# ── Discord 웹훅 (접근 요청 알림) ────────────────────
# 허용되지 않은 사용자가 접근 요청 버튼을 누르면 이 웹훅으로 알림이 전송됩니다.
# DISCORD_WEBHOOK_URL과 별개의 채널/웹훅을 사용하는 것을 권장합니다. (선택사항)
DISCORD_ACCESS_REQUEST_WEBHOOK_URL=YOUR_DISCORD_ACCESS_REQUEST_WEBHOOK_URL_HERE
