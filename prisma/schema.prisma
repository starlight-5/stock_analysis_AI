generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth 필수 테이블 ─────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())

  accounts  Account[]
  sessions  Session[]
  positions Position[]
  watchlist WatchlistItem[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── 포지션 ───────────────────────────────────────────────────────

model Position {
  id             String    @id @default(cuid())
  userId         String
  ticker         String
  name           String
  registeredAt   DateTime  @default(now())
  signal         String
  summary        String    @db.Text
  entryType      String
  entries        Json
  stopLoss       Float
  stopLossReason String
  targets        Json
  risks          Json
  holding        Json?
  status         String    @default("active")
  closedAt       DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

// ─── 접근 요청 ────────────────────────────────────────────────────

model AccessRequest {
  id          String    @id @default(cuid())
  email       String    @unique
  status      String    @default("pending") // pending | approved | rejected
  requestedAt DateTime  @default(now())
  reviewedAt  DateTime?
}

// ─── 차단 이메일 ──────────────────────────────────────────────────

model BannedEmail {
  id          String   @id @default(cuid())
  email       String   @unique
  bannedUntil DateTime
}

// ─── KIS 토큰 캐시 (Vercel 인스턴스 간 공유) ─────────────────────

model KisTokenCache {
  id        String   @id @default("kis_token")
  token     String   @db.Text
  expiresAt DateTime
  updatedAt DateTime @updatedAt
}

// ─── 일별 종목 추천 (섹터 기반 자동 전략 분석) ────────────────────

model DailyRecommendation {
  id          String   @id @default(cuid())
  date        String   // "2026-07-05" (KST 기준)
  sectorId    String
  sectorName  String
  sectorEmoji String
  ticker      String
  name        String
  market      String   // "US" | "KR"
  reason      String   // 섹터 내 선정 이유
  strategy    Json     // StrategyResult
  snapshot    Json     // IndicatorSnapshot
  signal      String   // 빠른 필터용 (strong_buy | buy | watch | sell | strong_sell)
  fallback    Boolean  @default(false) // true = 규칙 기반 폴백
  generatedAt DateTime @default(now())

  @@unique([date, ticker])
  @@index([date, sectorId])
  @@index([date, signal])
}

// ─── 관심종목 ─────────────────────────────────────────────────────

model WatchlistItem {
  id      String   @id @default(cuid())
  userId  String
  ticker  String
  name    String
  addedAt DateTime @default(now())
  memo    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker])
}
