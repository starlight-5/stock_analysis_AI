generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth 필수 테이블 ─────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  createdAt     DateTime  @default(now())

  accounts  Account[]
  sessions  Session[]
  positions Position[]
  watchlist WatchlistItem[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── 포지션 ───────────────────────────────────────────────────────

model Position {
  id             String    @id @default(cuid())
  userId         String
  ticker         String
  name           String
  registeredAt   DateTime  @default(now())
  signal         String
  summary        String    @db.Text
  entryType      String
  entries        Json
  stopLoss       Float
  stopLossReason String
  targets        Json
  risks          Json
  holding        Json?
  status         String    @default("active")
  closedAt       DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

// ─── 접근 요청 ────────────────────────────────────────────────────

model AccessRequest {
  id          String    @id @default(cuid())
  email       String    @unique
  status      String    @default("pending") // pending | approved | rejected
  requestedAt DateTime  @default(now())
  reviewedAt  DateTime?
}

// ─── 차단 이메일 ──────────────────────────────────────────────────

model BannedEmail {
  id          String   @id @default(cuid())
  email       String   @unique
  bannedUntil DateTime
}

// ─── 관심종목 ─────────────────────────────────────────────────────

model WatchlistItem {
  id      String   @id @default(cuid())
  userId  String
  ticker  String
  name    String
  addedAt DateTime @default(now())
  memo    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, ticker])
}
